# Server-side Gemini API key (used by /api/chat and Live Agent on VPS)
GEMINI_API_KEY=""

# Optional: baked into client bundle at build time (local dev). On VPS, GEMINI_API_KEY alone is enough.
NEXT_PUBLIC_GEMINI_API_KEY=""

# Public site URL (your production domain on VPS)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
