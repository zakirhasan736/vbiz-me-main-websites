# ── VPS / production ─────────────────────────────────────────────────────────
# Put this file on the SERVER as `.env` (project root, next to package.json).
# .env is gitignored — it is NOT uploaded when you git pull. Create it on the VPS.
# After editing, RESTART the Node process (pm2 restart, docker restart, etc.).

# Primary key (server reads this at runtime — no rebuild needed)
GEMINI_API_KEY=""

# Optional: only needed if you want the key baked into the client bundle at build time
NEXT_PUBLIC_GEMINI_API_KEY=""

# Your live site URL (must be HTTPS for Live Agent microphone + WebSocket)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── Google AI Studio (required for Live Agent on your domain) ────────────────
# API key → Application restrictions → HTTP referrers → add:
#   https://yourdomain.com/*
#   https://www.yourdomain.com/*
